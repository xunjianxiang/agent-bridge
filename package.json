{
  "name": "agent-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "A lightweight API gateway for local AI coding agent SDKs.",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "start": "node dist/src/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run --config vitest.unit.config.ts",
    "smoke": "node --disable-warning=ExperimentalWarning scripts/smoke-test.ts",
    "verify": "npm run test && npm run typecheck && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.153",
    "@google/gemini-cli-core": "^0.44.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-fastify": "^11.1.6",
    "@openai/codex-sdk": "^0.134.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
